.unity-list-view__item:hover {
    background-color: transparent;
}

.main-scroll {
    padding: 0;
}

.section-foldout {
    margin-bottom: 4px;
    padding: 2px;
}

.section-foldout > .unity-foldout__content {
    padding: 4px;
}

.section-content {
    padding-left: 0;
}

.section-header {
    font-weight: bold;
    margin-top: 8px;
    margin-left: 2px;
    -unity-font-style: bold;
    left: 2px;
}

.spline-count-info {
    color: rgb(255, 255, 255);
    font-size: 11px;
    margin-left: 8px;
    margin-top: 8px;
    -unity-font-style: bold;
    align-self: center;
}

.splines-header-container {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4px;
    margin-right: 4px;
    margin-left: -2px;
}

.splines-header-buttons {
    flex-direction: row;
    align-items: center;
    gap: 4px;
}

.section-header-icon-button {
    width: 20px;
    height: 20px;
    min-width: 20px;
    min-height: 20px;
    margin-left: 4px;
    padding: 0;
    border-width: 0;
    border-radius: 0;
    background-color: transparent;
    align-self: center;
}

.section-header-icon-button:hover {
    background-color: rgb(58, 58, 58);
}

.section-header-icon-button:active {
    background-color: rgb(42, 42, 42);
}

.section-header-icon {
    width: 16px;
    height: 16px;
    margin: 2px;
    -unity-background-scale-mode: scale-and-crop;
    -unity-image-tint-color: rgb(204, 204, 204);
}

.section-header-icon-button:hover .section-header-icon {
    -unity-image-tint-color: rgb(255, 255, 255);
}

.section-header-status-icon {
    margin-right: 4px;
}

.splines-header-buttons .spline-action-button {
    opacity: 1;
    min-width: 20px;
    min-height: 20px;
    width: 20px;
    height: 20px;
    margin-left: 4px;
    padding: 0;
    border-width: 0;
    border-radius: 0;
    flex-shrink: 0;
}

.splines-header-buttons .spline-action-button:hover {
    background-color: rgb(58, 58, 58);
    border-color: transparent;
    color: rgb(255, 255, 255);
}

.splines-header-buttons .spline-action-button:active {
    background-color: rgb(42, 42, 42);
    border-color: transparent;
}

.splines-header-buttons .spline-action-icon {
    width: 16px;
    height: 16px;
    -unity-background-scale-mode: scale-and-crop;
    -unity-image-tint-color: rgb(204, 204, 204);
    margin: 2px;
}

.splines-header-buttons .spline-action-button:hover .spline-action-icon {
    -unity-image-tint-color: rgb(255, 255, 255);
}

.button-row {
    flex-direction: row;
    justify-content: flex-start;
    align-items: center;
    margin-top: 4px;
}

.credits-container {
    margin-top: 4px;
    align-self: center;
    cursor: pointer;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    gap: 4px;
}

.credits-label-text {
    color: rgb(170, 170, 170);
    font-size: 11px;
    -unity-text-align: middle-center;
}

.credits-label-link {
    color: rgb(170, 170, 170);
    font-size: 11px;
    -unity-text-align: middle-center;
    border-bottom-width: 1px;
    border-bottom-color: rgb(170, 170, 170);
    padding-bottom: 1px;
}

.action-button {
    min-width: 80px;
    height: 24px;
    margin-right: 8px;
    flex-grow: 1;
}

.action-button:last-child {
    margin-right: 0;
}

.mode-toolbar {
    flex-direction: row;
    margin-bottom: 4px;
}

.mode-radio {
    min-width: 60px;
    margin-right: 4px;
}

.mode-toolbar .unity-text-element.mode-button {
    min-width: auto;
    height: 24px;
    margin-right: 2px;
    border-radius: 3px;
    flex-grow: 1;
    background-color: transparent;
}

.mode-toolbar .unity-text-element.mode-button:last-child {
    margin-right: 0;
}

.mode-toolbar .unity-text-element.mode-button.mode-button-selected {
    background-color: rgb(42, 42, 42);
    border-color: transparent;
}

.mode-toolbar .unity-text-element.mode-button.mode-button-selected:hover {
    background-color: rgb(42, 42, 42);
    border-color: rgb(82, 82, 82);
}

.operation-mode-container {
    flex-direction: row;
    align-items: center;
    margin-top: 4px;
    margin-bottom: 8px;
    padding: 4px;
    display: flex;
    visibility: visible;
    opacity: 1;
    min-height: 22px;
}

.operation-icon-toggle {
    width: 22px;
    height: 22px;
    min-width: 22px;
    min-height: 22px;
    padding: 0;
    margin-right: 6px;
    justify-content: center;
    align-items: center;
    background-color: transparent;
    border-width: 0;
    padding-bottom: 0;
    bottom: -2px;
}

.operation-icon-toggle:last-child {
    margin-right: 0;
}

.operation-icon-toggle > .unity-toggle__input {
    display: none;
}

.operation-icon-toggle > .unity-toggle__label {
    display: none;
}

.icon-toggle {
    width: 22px;
    height: 22px;
    min-width: 22px;
    min-height: 22px;
    padding: 0;
    margin-left: 4px;
    background-color: transparent;
    border-width: 0;
    justify-content: center;
    align-items: center;
}

.icon-toggle > .unity-toggle__input {
    display: none;
}

.icon-toggle > .unity-toggle__label {
    display: none;
}

.icon-toggle-icon {
    width: 16px;
    height: 16px;
    margin: 2px;
    -unity-background-scale-mode: scale-and-crop;
}

.operation-icon {
    width: 18px;
    height: 18px;
    -unity-background-scale-mode: scale-and-crop;
}

.global-operation-icon {
    margin-right: 6px;
    margin-left: 6px;
    min-width: 18px;
    min-height: 18px;
    -unity-image-tint-color: rgb(119, 119, 119);
}

.global-operation-dropdown {
    margin-right: 8px;
    width: 120px;
    min-width: 120px;
    max-width: 150px;
    display: flex;
    visibility: visible;
    opacity: 1;
}

.global-operation-dropdown > .unity-enum-field__label {
    min-width: 60px;
}

.global-operation-dropdown > .unity-enum-field__input {
    flex-grow: 1;
}

.operation-dropdown {
    margin-left: 8px;
    width: 120px;
    min-width: 120px;
    max-width: 150px;
    display: flex;
    visibility: visible;
    opacity: 1;
}

.operation-dropdown > .unity-enum-field__label {
    min-width: 60px;
}

.operation-dropdown > .unity-enum-field__input {
    flex-grow: 1;
}

.operation-warning-label {
    color: rgb(255, 68, 68);
    font-size: 10px;
    margin-left: 8px;
    margin-top: 0;
    -unity-font-style: italic;
}

.splines-scroll-container {
    min-height: 200px;
    max-height: 500px;
    background-color: transparent;
    margin-top: 4px;
    margin-left: -8px;
}

.preview-textures-row {
    flex-direction: row;
    margin-top: 8px;
    margin-bottom: 8px;
}

.preview-texture-container {
    flex-grow: 1;
    align-items: center;
    margin-right: 16px;
}

.preview-texture-container:last-child {
    margin-right: 0;
}

.preview-label {
    -unity-font-style: bold;
    margin-bottom: 4px;
    -unity-text-align: middle-center;
}

.preview-texture {
    width: 200px;
    height: 200px;
    min-width: 200px;
    min-height: 200px;
}

.cache-info {
    margin-left: 8px;
    opacity: 0.7;
}

.backend-status {
    -unity-font-style: bold;
    margin-bottom: 8px;
    margin-left: 0;
    left: 2px;
}

.backend-status.gpu {
    color: rgb(76, 175, 80);
}

.backend-status.cpu {
    color: rgb(255, 152, 0);
}

.unity-slider {
    margin-bottom: 2px;
}

.unity-object-field {
    margin-bottom: 2px;
}

.unity-toggle {
    margin-bottom: 2px;
}

.unity-curve-field {
    margin-bottom: 2px;
}

.slider-field-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: 2px;
    margin-left: 2px;
}

.slider-field-row > .unity-slider {
    flex-grow: 1;
    min-width: 140px;
    flex-basis: 0;
    margin-right: 8px;
    margin-bottom: 0;
}

.slider-field-row > .unity-slider > .unity-slider__label {
    min-width: 90px;
    margin-right: 8px;
    padding-left: 0;
}

.slider-field-row > .unity-slider-int > .unity-slider__label {
    min-width: 90px;
    margin-right: 8px;
    padding-left: 0;
    margin-left: 0;
    padding-left: -2px;
}

.slider-field-row > .unity-base-slider {
    flex-grow: 1;
    min-width: 140px;
    flex-basis: 0;
    margin-right: 8px;
    margin-bottom: 0;
}

.slider-field-row > .unity-slider-int {
    flex-grow: 1;
    min-width: 140px;
    flex-basis: 0;
    margin-right: 8px;
    margin-bottom: 0;
    margin-left: 0;
}

.slider-field-row .unity-label {
    min-width: 90px;
    margin-right: 8px;
    padding-left: 0;
}

.slider-field-row > .unity-float-field {
    width: 60px;
    min-width: 60px;
    margin-bottom: 0;
}

.slider-field-row > .unity-integer-field {
    width: 60px;
    min-width: 60px;
    margin-bottom: 0;
}

.brush-field-container {
    margin-bottom: 4px;
}

.single-brush-field {
    margin-top: 4px;
}

.brush-preview-with-checkerboard {
    width: 64px;
    height: 64px;
    min-width: 64px;
    min-height: 64px;
    border: 1px solid rgb(102, 102, 102);
    border-radius: 2px;
    background-color: rgb(30, 30, 30);
    overflow: hidden;
    position: relative;
    background-image: linear-gradient(45deg, rgb(102, 102, 102) 25%, transparent 25%), linear-gradient(-45deg, rgb(102, 102, 102) 25%, transparent 25%), linear-gradient(45deg, transparent 75%, rgb(102, 102, 102) 75%), linear-gradient(-45deg, transparent 75%, rgb(102, 102, 102) 75%);
    background-size: 8px 8px;
    background-position: 0 0, 0 4px, 4px -4px, -4px 0;
}

.brush-texture-image {
    width: 100%;
    height: 100%;
    background-color: transparent;
    position: absolute;
    top: 0;
    left: 0;
}

.brush-select-btn-overlay {
    position: absolute;
    bottom: 2px;
    left: 50%;
    margin-left: -20px;
    min-width: 40px;
    width: 40px;
    height: 16px;
    font-size: 10px;
    border-radius: 2px;
    color: rgb(255, 255, 255);
    z-index: 10;
    opacity: 0;
    transition: opacity 0.2s ease;
}

.brush-preview-with-checkerboard:hover .brush-select-btn-overlay {
    opacity: 1;
}

.hidden-object-field {
    display: none;
}

.size-multiplier-row {
    flex-direction: row;
    align-items: center;
    margin-bottom: -4px;
    margin-left: 2px;
    margin-right: 0;
    margin-top: 0;
}

.size-multiplier-row > .unity-label {
    min-width: 100px;
    margin-right: 8px;
    margin-bottom: 0;
}

.size-multiplier-row > .unity-toggle {
    margin-right: 8px;
    margin-top: 8px;
}

.size-multiplier-row > .unity-curve-field {
    flex-grow: 1;
    margin-bottom: 2px;
}

.height-range-info {
    margin-top: 4px;
    opacity: 0.8;
    font-size: 11px;
    margin-left: 4px;
    left: 2px;
}

.paint-section {
    margin-top: 8px;
    margin-bottom: 8px;
}

.paint-layer-selection {
    margin-top: 4px;
    margin-bottom: 4px;
}

.paint-layer-palette {
    flex-direction: row;
    flex-wrap: wrap;
    margin-top: 4px;
    gap: 4px;
}

.layer-button {
    flex-direction: column;
    align-items: center;
    padding: 4px;
    margin: 2px;
    min-width: 60px;
    min-height: 60px;
    border-width: 1px;
    border-radius: 4px;
    position: relative;
}

.layer-button-selected {
    background-color: rgb(74, 144, 226);
    border-color: rgb(255, 255, 255);
}

.layer-button-unselected {
    background-color: rgb(45, 45, 45);
    border-color: rgb(85, 85, 85);
}

.layer-button:hover {
    background-color: rgb(58, 123, 200);
}

.layer-thumbnail {
    width: 32px;
    height: 32px;
    margin-bottom: 2px;
    border-radius: 2px;
}

.layer-name {
    font-size: 10px;
    text-align: center;
    max-width: 60px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.layer-noise-badge {
    position: absolute;
    top: 2px;
    right: 2px;
    width: 12px;
    height: 12px;
    opacity: 0.9;
}

.noise-foldout {
    margin-top: 4px;
    padding: 0;
}

.noise-foldout > .unity-toggle {
    background-color: rgb(48, 48, 48);
    padding: 4px 0;
    margin: 0;
    flex-direction: row;
    align-items: center;
    min-height: 22px;
}

.noise-foldout > .unity-toggle #unity-checkmark {
    display: flex;
    opacity: 1;
    margin-left: 3px;
    margin-right: 6px;
}

.noise-foldout > .unity-toggle .unity-label {
    font-weight: normal;
    margin-left: 2px;
    margin-top: 0;
    color: rgb(255, 255, 255);
    -unity-font-style: normal;
    align-self: center;
    -unity-background-scale-mode: scale-to-fit;
}

.noise-header-icon {
    width: 12px;
    height: 12px;
    margin-left: 2px;
    margin-right: 16px;
    align-self: center;
    -unity-background-scale-mode: scale-to-fit;
    -unity-image-tint-color: rgb(204, 204, 204);
}

.noise-foldout-content {
    margin-top: 2px;
}

.noise-inline-row {
    flex-direction: row;
    align-items: center;
    gap: 8px;
    margin-bottom: 2px;
}

.noise-inline-row .noise-texture-field {
    flex-grow: 1;
    margin-right: 0;
    margin-left: 1px;
}

.noise-invert-toggle {
    align-self: center;
    width: 22px;
    height: 22px;
    min-width: 22px;
    min-height: 22px;
    padding: 0;
    margin-left: 0;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    margin-bottom: 0;
    margin-top: -8px;
    padding-top: 0;
    top: 8px;
}

.noise-invert-toggle .unity-toggle__checkmark {
    display: none;
}

.noise-invert-toggle .unity-toggle__input {
    display: none;
}

.noise-invert-toggle .unity-label {
    display: none;
}

.noise-offset-field {
    margin-left: 4px;
    padding-left: 0;
}

.noise-offset-field .unity-base-field__label {
    margin-left: 0;
    margin-right: 0;
    padding-left: 0;
}

.no-layers-label {
    color: rgb(136, 136, 136);
    font-style: italic;
    margin: 8px;
}

.divider {
    flex-grow: 1;
    padding-top: 1px;
    background-color: rgb(65, 65, 65);
    margin-bottom: 8px;
    margin-top: 0;
}

.divider {
    padding-top: 16px;
}

.divider {
    padding-top: 1px;
}

.section-foldout > .unity-toggle {
    background-color: rgb(48, 48, 48);
    padding: 4px 0;
    margin: 0;
}

.section-foldout > .unity-toggle #unity-checkmark {
    opacity: 0;
    margin-left: 3px;
    margin-right: 6px;
}

.section-foldout:hover > .unity-toggle #unity-checkmark {
    opacity: 1;
}

.divider {
    padding: 0;
    margin: 0;
}

.section-foldout {
}

.section-foldout:hover .unity-toggle .unity-label {
    color: rgb(255, 255, 255);
}

.main-scroll {
    margin-top: 8px;
}

.unity-toggle .unity-label {
    -unity-font-style: bold;
}

.plain-toggle .unity-label {
    -unity-font-style: normal;
}

.unity-object-field {
    margin-left: 0;
    margin-right: 0;
}

.unity-button {
    margin-left: 0;
    margin-right: 0;
}

.unity-label {
    margin-left: 0;
    margin-right: 0;
    padding-left: 0;
}

.unity-toggle__checkmark {
    opacity: 1;
    display: flex;
}

.divider {
    background-color: rgba(255, 255, 255, 0.06);
}

.unity-slider {
    margin-left: 0;
    margin-right: 0;
}

.spline-tab-button {
    height: 28px;
    font-size: 11px;
    background-color: rgba(0, 0, 0, 0.2);
    border-bottom: 2px solid transparent;
    color: rgb(170, 170, 170);
}

.spline-tab-button.spline-tab-button-active {
    background-color: transparent;
    border-bottom: 2px solid rgb(74, 158, 255);
    color: rgb(255, 255, 255);
    font-weight: bold;
}

.group-item-content > .spline-item-nested {
    padding-top: 4px;
}

.overlay-title-buttons {
}

.performance-timing-info {
    margin-left: 3px;
}
